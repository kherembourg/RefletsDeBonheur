---
// Enable SSR for dynamic slugs
export const prerender = false;

import MainLayout from '../../layouts/MainLayout.astro';
import AdminAccessGuard from '../../components/admin/AdminAccessGuard.astro';
import { AdminPanel } from '../../components/admin/AdminPanel';
import { getWeddingBySlugAsync, shouldUseDemoWeddingMode } from '../../lib/weddingData';
import { isSupabaseServiceRoleConfigured, verifyServerSession, verifyWeddingOwnership } from '../../lib/supabase/server';

const { slug } = Astro.params;
const wedding = await getWeddingBySlugAsync(slug as string);

if (!wedding) {
  return Astro.redirect('/404');
}

// Server-side auth check: verify the user owns this wedding
// Only enforce when Supabase is configured (skip for demo/mock data mode)
const demoMode = shouldUseDemoWeddingMode(wedding);

if (isSupabaseServiceRoleConfigured() && !demoMode) {
  const session = await verifyServerSession(Astro.cookies);

  if (!session) {
    // No valid server session — redirect to login with expired flag
    // to prevent redirect loop (localStorage may still have stale tokens)
    return Astro.redirect('/connexion?expired=1');
  }

  // Verify the authenticated user owns this wedding
  const isOwner = await verifyWeddingOwnership(session.userId, wedding.id);

  if (!isOwner) {
    // User is authenticated but doesn't own this wedding
    return Astro.redirect('/connexion?expired=1');
  }
}
---

<MainLayout
  title={`Administration - ${wedding.name}`}
  description={`Panneau d'administration pour ${wedding.name}`}
  showHeader={false}
>
  <AdminPanel
    client:load
    weddingId={wedding.id}
    weddingSlug={slug}
    profileId={wedding.ownerId}
    initialView="dashboard"
  />
  <AdminAccessGuard clearStaleClientSession={true} />
</MainLayout>
