---
/**
 * God Impersonation Handler
 * Verifies access token and sets up client session
 */
import '../../styles/global.css';
---

<!DOCTYPE html>
<html lang="fr">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <meta name="robots" content="noindex, nofollow" />
  <title>Accès client - God Admin</title>

  <link rel="preconnect" href="https://fonts.googleapis.com" />
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
  <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600&display=swap" rel="stylesheet" />
</head>
<body class="min-h-screen m-0 flex items-center justify-center bg-linear-to-br from-gray-800 to-gray-950 font-sans">
  <div
    id="status-container"
    class="w-full max-w-md rounded-3xl border border-white/10 bg-white/5 p-8 text-center shadow-2xl backdrop-blur-sm"
  >
    <div class="mx-auto mb-6 h-12 w-12 rounded-full border-[3px] border-gray-700 border-t-amber-500 animate-spin"></div>
    <p class="mb-2 text-xl font-semibold text-gray-50">Vérification de l&apos;accès...</p>
    <p class="text-sm text-gray-400">Veuillez patienter</p>
  </div>

  <script type="module" src="/scripts/god-impersonate.js"></script>
</body>
</html>
