---
import MainLayout from '../layouts/MainLayout.astro';
import { ResetPasswordForm } from '../components/auth/ResetPasswordForm';
import { getLangFromUrl, t } from '../i18n/utils';

const lang = getLangFromUrl(Astro.url);
---

<MainLayout title={t(lang, 'resetPassword.pageTitle')} lang={lang} showHeader={false}>
  <section class="min-h-screen bg-gradient-to-b from-cream to-white px-4 py-12 flex items-center justify-center">
    <div class="w-full max-w-xl">
      <ResetPasswordForm client:load lang={lang} />
    </div>
  </section>
</MainLayout>
