---
import MainLayout from '../layouts/MainLayout.astro';
import { ResetPasswordForm } from '../components/auth/ResetPasswordForm';
---

<MainLayout title="Réinitialiser le mot de passe" showHeader={false}>
  <section class="min-h-screen bg-gradient-to-b from-cream to-white px-4 py-12 flex items-center justify-center">
    <div class="w-full max-w-xl">
      <ResetPasswordForm client:load />
    </div>
  </section>
</MainLayout>
