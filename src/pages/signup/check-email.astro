---
import MainLayout from '../../layouts/MainLayout.astro';
import { getLangFromUrl, t } from '../../i18n/utils';

export const prerender = false;

const lang = getLangFromUrl(Astro.url);
const email = Astro.url.searchParams.get('email') || '';
const slug = Astro.url.searchParams.get('slug') || '';
---

<MainLayout title={t(lang, 'signup.checkEmail.title')} lang={lang}>
  <section class="min-h-screen bg-gradient-to-b from-cream to-white px-4 py-12 flex items-center justify-center">
    <div class="w-full max-w-2xl rounded-3xl border border-charcoal/5 bg-white p-8 shadow-sm sm:p-10">
      <div class="mx-auto mb-6 flex h-16 w-16 items-center justify-center rounded-full bg-emerald-50 text-emerald-600">
        <svg class="h-8 w-8" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7" />
        </svg>
      </div>

      <div class="text-center">
        <p class="text-xs uppercase tracking-[0.25em] text-charcoal/45">{t(lang, 'signup.checkEmail.eyebrow')}</p>
        <h1 class="mt-3 font-serif text-4xl text-charcoal">{t(lang, 'signup.checkEmail.title')}</h1>
        <p class="mt-4 text-base leading-relaxed text-charcoal/65">
          {t(lang, 'signup.checkEmail.message')}
          {' '}
          <strong class="text-charcoal">{email || t(lang, 'signup.checkEmail.fallbackEmail')}</strong>.
        </p>
      </div>

      <div class="mt-8 rounded-2xl bg-[#faf6f4] p-6">
        <h2 class="font-medium text-charcoal">{t(lang, 'signup.checkEmail.nextStepsTitle')}</h2>
        <ol class="mt-4 space-y-3 text-sm text-charcoal/70">
          <li>1. {t(lang, 'signup.checkEmail.step1')}</li>
          <li>2. {t(lang, 'signup.checkEmail.step2')}</li>
          <li>3. {t(lang, 'signup.checkEmail.step3')}</li>
        </ol>
      </div>

      <div class="mt-8 grid gap-3 sm:grid-cols-2">
        <a
          href={slug ? `/connexion?mode=client&email=${encodeURIComponent(email)}` : `/connexion?mode=client&email=${encodeURIComponent(email)}`}
          class="inline-flex items-center justify-center rounded-lg bg-burgundy-old px-5 py-3 text-sm font-medium text-white transition-colors hover:bg-burgundy-dark"
        >
          {t(lang, 'signup.checkEmail.loginCta')}
        </a>
        <a
          href={slug ? `/${slug}` : '/'}
          class="inline-flex items-center justify-center rounded-lg border border-charcoal/10 px-5 py-3 text-sm font-medium text-charcoal transition-colors hover:bg-charcoal/5"
        >
          {t(lang, 'signup.checkEmail.publicSiteCta')}
        </a>
      </div>

      <div class="mt-4 flex justify-center">
        <button
          id="resend-access-email"
          type="button"
          class="inline-flex items-center justify-center rounded-lg border border-charcoal/10 px-4 py-2 text-sm font-medium text-charcoal transition-colors hover:bg-charcoal/5 disabled:cursor-not-allowed disabled:opacity-50"
          disabled={!email || !slug}
        >
          {t(lang, 'signup.checkEmail.resendCta')}
        </button>
      </div>

      <p id="resend-access-email-status" class="mt-3 text-center text-xs text-charcoal/55" aria-live="polite"></p>

      <p class="mt-6 text-center text-xs text-charcoal/50">
        {t(lang, 'signup.checkEmail.help')}
      </p>
    </div>
  </section>
</MainLayout>

<script define:vars={{ email, slug, lang }}>
  const resendButton = document.getElementById('resend-access-email');
  const resendStatus = document.getElementById('resend-access-email-status');

  if (resendButton && resendStatus) {
    const messages = {
      fr: {
        idle: 'Renvoyer l’email',
        loading: 'Envoi en cours…',
        success: 'Un nouvel email d’accès vient d’être envoyé.',
        error: 'Impossible de renvoyer l’email pour le moment. Essayez depuis la page de connexion.',
      },
      en: {
        idle: 'Resend email',
        loading: 'Sending…',
        success: 'A new access email has just been sent.',
        error: 'Unable to resend the email right now. Try again from the login page.',
      },
      es: {
        idle: 'Reenviar correo',
        loading: 'Enviando…',
        success: 'Se acaba de enviar un nuevo correo de acceso.',
        error: 'No se pudo reenviar el correo en este momento. Inténtalo desde la página de acceso.',
      },
    };

    const copy = messages[lang] || messages.en;

    resendButton.addEventListener('click', async () => {
      resendButton.setAttribute('disabled', 'true');
      resendButton.textContent = copy.loading;
      resendStatus.textContent = '';

      try {
        const response = await fetch('/api/signup/resend-access-email', {
          method: 'POST',
          headers: { 'Content-Type': 'application/json' },
          body: JSON.stringify({ email, slug }),
        });

        if (!response.ok) {
          throw new Error('Resend failed');
        }

        resendStatus.textContent = copy.success;
      } catch (error) {
        console.error('[Check Email] Resend access email failed:', error);
        resendStatus.textContent = copy.error;
      } finally {
        resendButton.removeAttribute('disabled');
        resendButton.textContent = copy.idle;
      }
    });
  }
</script>
