---
import MainLayout from '../../layouts/MainLayout.astro';
import { getLangFromUrl, t } from '../../i18n/utils';

export const prerender = false;

const lang = getLangFromUrl(Astro.url);
const email = Astro.url.searchParams.get('email') || '';
const slug = Astro.url.searchParams.get('slug') || '';
---

<MainLayout title={t(lang, 'signup.checkEmail.title')} lang={lang}>
  <section class="min-h-screen bg-gradient-to-b from-cream to-white px-4 py-12 flex items-center justify-center">
    <div class="w-full max-w-2xl rounded-3xl border border-charcoal/5 bg-white p-8 shadow-sm sm:p-10">
      <div class="mx-auto mb-6 flex h-16 w-16 items-center justify-center rounded-full bg-emerald-50 text-emerald-600">
        <svg class="h-8 w-8" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7" />
        </svg>
      </div>

      <div class="text-center">
        <p class="text-xs uppercase tracking-[0.25em] text-charcoal/45">{t(lang, 'signup.checkEmail.eyebrow')}</p>
        <h1 class="mt-3 font-serif text-4xl text-charcoal">{t(lang, 'signup.checkEmail.title')}</h1>
        <p class="mt-4 text-base leading-relaxed text-charcoal/65">
          {t(lang, 'signup.checkEmail.message')}
          {' '}
          <strong class="text-charcoal">{email || t(lang, 'signup.checkEmail.fallbackEmail')}</strong>.
        </p>
      </div>

      <div class="mt-8 rounded-2xl bg-[#faf6f4] p-6">
        <h2 class="font-medium text-charcoal">{t(lang, 'signup.checkEmail.nextStepsTitle')}</h2>
        <ol class="mt-4 space-y-3 text-sm text-charcoal/70">
          <li>1. {t(lang, 'signup.checkEmail.step1')}</li>
          <li>2. {t(lang, 'signup.checkEmail.step2')}</li>
          <li>3. {t(lang, 'signup.checkEmail.step3')}</li>
        </ol>
      </div>

      <div class="mt-8 grid gap-3 sm:grid-cols-2">
        <a
          href={slug ? `/connexion?mode=client&email=${encodeURIComponent(email)}` : `/connexion?mode=client&email=${encodeURIComponent(email)}`}
          class="inline-flex items-center justify-center rounded-lg bg-burgundy-old px-5 py-3 text-sm font-medium text-white transition-colors hover:bg-burgundy-dark"
        >
          {t(lang, 'signup.checkEmail.loginCta')}
        </a>
        <a
          href={slug ? `/${slug}` : '/'}
          class="inline-flex items-center justify-center rounded-lg border border-charcoal/10 px-5 py-3 text-sm font-medium text-charcoal transition-colors hover:bg-charcoal/5"
        >
          {t(lang, 'signup.checkEmail.publicSiteCta')}
        </a>
      </div>

      <p class="mt-6 text-center text-xs text-charcoal/50">
        {t(lang, 'signup.checkEmail.help')}
      </p>
    </div>
  </section>
</MainLayout>
