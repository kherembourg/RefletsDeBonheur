---
import '../styles/global.css';
import InstallPrompt from '../components/pwa/InstallPrompt';
import { CookieConsent } from '../components/layout/CookieConsent';
import LanguageDetector from '../components/layout/LanguageDetector.astro';
import { getLangFromUrl, getHtmlLang } from '../i18n/utils';

interface Props {
  title: string;
  description?: string;
  showHeader?: boolean;
}

const {
  title,
  description = "Share the magic of your wedding with elegance",
  showHeader = true
} = Astro.props;

// Get current language from URL
const currentLang = getLangFromUrl(Astro.url);
const htmlLang = getHtmlLang(currentLang);
---

<!DOCTYPE html>
<html lang={htmlLang}>
  <head>
    <meta charset="UTF-8" />
    <!-- Language Detection - Redirects based on browser language on first visit -->
    <LanguageDetector />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>{title} | Reflets de Bonheur</title>
    <meta name="description" content={description} />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />

    <!-- Preconnect to image CDNs for faster loading -->
    <link rel="preconnect" href="https://images.unsplash.com" />
    <link rel="dns-prefetch" href="https://images.unsplash.com" />

    <!-- PWA Meta Tags -->
    <link rel="manifest" href="/manifest.json" />
    <meta name="theme-color" content="#f5f0e8" media="(prefers-color-scheme: light)" />
    <meta name="theme-color" content="#0f0f0f" media="(prefers-color-scheme: dark)" />
    <meta name="apple-mobile-web-app-capable" content="yes" />
    <meta name="apple-mobile-web-app-status-bar-style" content="black-translucent" />
    <meta name="apple-mobile-web-app-title" content="Reflets" />

    <!-- iOS Icons -->
    <link rel="apple-touch-icon" href="/icons/icon-192x192.png" />
    <link rel="apple-touch-icon" sizes="152x152" href="/icons/icon-152x152.png" />
    <link rel="apple-touch-icon" sizes="180x180" href="/icons/icon-192x192.png" />
    <link rel="apple-touch-icon" sizes="167x167" href="/icons/icon-192x192.png" />

    <!-- Android/Chrome -->
    <meta name="mobile-web-app-capable" content="yes" />

    <!-- Microsoft -->
    <meta name="msapplication-TileColor" content="#ae1725" />
    <meta name="msapplication-TileImage" content="/icons/icon-144x144.png" />

    <!-- Preconnect for fonts and images -->
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />

    <!-- Google Fonts - Elegant French-inspired typography with display=swap for fast rendering -->
    <link href="https://fonts.googleapis.com/css2?family=Playfair+Display:wght@400;600;700&family=Cormorant+Garamond:ital,wght@0,300;0,400;0,500;0,600;1,300;1,400&family=Montserrat:wght@300;400;500;600;700&family=Great+Vibes&family=Allura&display=swap" rel="stylesheet" />
  </head>
  <body class="min-h-screen bg-cream text-charcoal font-sans">
    <a href="#main-content" class="skip-link">Skip to content</a>
    {showHeader && (
      <slot name="header" />
    )}

    <main id="main-content" tabindex="-1">
      <slot />
    </main>

    <slot name="footer" />

    <!-- PWA Install Prompt -->
    <InstallPrompt client:load />

    <!-- Service Worker Registration -->
    <script is:inline>
      if ('serviceWorker' in navigator) {
        let updatePromptVisible = false;

        const showUpdatePrompt = (newWorker) => {
          if (updatePromptVisible) return;
          updatePromptVisible = true;

          const existingPrompt = document.getElementById('sw-update-prompt');
          if (existingPrompt) {
            existingPrompt.remove();
          }

          const prompt = document.createElement('div');
          prompt.id = 'sw-update-prompt';
          prompt.setAttribute('role', 'status');
          prompt.className = 'fixed bottom-4 left-4 right-4 z-[100] mx-auto max-w-md rounded-2xl border border-charcoal/10 bg-white px-4 py-4 shadow-2xl';
          prompt.innerHTML = `
            <div class="flex items-start gap-3">
              <div class="mt-0.5 h-2.5 w-2.5 shrink-0 rounded-full bg-burgundy-old"></div>
              <div class="min-w-0 flex-1">
                <p class="text-sm font-semibold text-charcoal">Nouvelle version disponible</p>
                <p class="mt-1 text-sm text-charcoal/65">Rafraîchir maintenant pour activer la dernière version.</p>
              </div>
            </div>
            <div class="mt-4 flex items-center justify-end gap-2">
              <button type="button" data-action="dismiss" class="rounded-full px-3 py-2 text-sm font-medium text-charcoal/70 transition hover:bg-charcoal/5 hover:text-charcoal">Plus tard</button>
              <button type="button" data-action="refresh" class="rounded-full bg-burgundy-old px-4 py-2 text-sm font-medium text-white transition hover:bg-[#c92a38]">Rafraîchir</button>
            </div>
          `;

          prompt.querySelector('[data-action="dismiss"]')?.addEventListener('click', () => {
            updatePromptVisible = false;
            prompt.remove();
          });

          prompt.querySelector('[data-action="refresh"]')?.addEventListener('click', () => {
            newWorker.postMessage({ type: 'SKIP_WAITING' });
            window.location.reload();
          });

          document.body.appendChild(prompt);
        };

        window.addEventListener('load', () => {
          navigator.serviceWorker
            .register('/sw.js')
            .then((registration) => {
              console.log('[SW] Service Worker registered:', registration);

              // Check for updates every hour
              setInterval(() => {
                registration.update();
              }, 60 * 60 * 1000);

              // Listen for updates
              registration.addEventListener('updatefound', () => {
                const newWorker = registration.installing;
                if (newWorker) {
                  newWorker.addEventListener('statechange', () => {
                    if (newWorker.state === 'installed' && navigator.serviceWorker.controller) {
                      // New version available
                      console.log('[SW] New version available');
                      showUpdatePrompt(newWorker);
                    }
                  });
                }
              });
            })
            .catch((error) => {
              console.error('[SW] Registration failed:', error);
            });

          // Handle controller change (new SW activated)
          navigator.serviceWorker.addEventListener('controllerchange', () => {
            console.log('[SW] Controller changed, reloading page');
            window.location.reload();
          });
        });
      } else {
        console.log('[SW] Service Worker not supported');
      }
    </script>
    <CookieConsent client:load />
  </body>
</html>
