---
interface Props {
  clearStaleClientSession?: boolean;
  redirectTo?: string;
}

const {
  clearStaleClientSession = false,
  redirectTo = '/connexion',
} = Astro.props;
---

<script define:vars={{ clearStaleClientSession, redirectTo }}>
  if (typeof window !== 'undefined') {
    const clientSession = localStorage.getItem('reflets_client_session');
    const godImpersonation = localStorage.getItem('reflets_god_impersonation');
    const guestSession = localStorage.getItem('reflets_guest_session');

    let hasAccess = false;

    if (clientSession) {
      hasAccess = true;
    } else if (godImpersonation) {
      hasAccess = true;
    } else if (guestSession) {
      try {
        const session = JSON.parse(guestSession);
        if (session.access_type === 'admin') {
          hasAccess = true;
        }
      } catch {}
    }

    if (localStorage.getItem('reflets_is_admin') === 'true') {
      hasAccess = true;
    }

    if (!hasAccess) {
      if (clearStaleClientSession) {
        localStorage.removeItem('reflets_client_token');
        localStorage.removeItem('reflets_client_session');
      }

      window.location.href = redirectTo;
    }
  }
</script>
